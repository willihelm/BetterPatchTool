# Convex client URL (REQUIRED): used by the browser to talk to Convex.
# Example: https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud

# Convex Auth site URL (AUTH ONLY): used by `convex/auth.config.ts`.
# Example: https://your-deployment.convex.site
# This is separate from NEXT_PUBLIC_CONVEX_URL and should also be set in Convex env.
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-convex-deployment.convex.site

# Generate a strong secret (32+ random bytes), e.g. openssl rand -base64 32
# Use the SAME value here and in Convex env: bunx convex env set MCP_TOKEN_PEPPER <secret>
MCP_TOKEN_PEPPER=replace-with-a-long-random-secret

# GitHub OAuth (set these on the Convex dashboard, not in .env.local)
# AUTH_GITHUB_ID=your-github-oauth-app-client-id
# AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret
